<!-- [LOCALIZADOR: MainWindow.xaml | COM-001] Janela principal da aplicação: reúne formulário, tabela e resumo das encomendas. -->
<Window x:Class="BaconreUs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bacon're Us - Encomendas" Height="620" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Pizzaria Bacon're Us - Sistema de Takeaway"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0 0 0 12"/>

        <!-- [LOCALIZADOR: MainWindow.xaml | COM-002] Formulário onde o utilizador escreve os dados da encomenda. -->
        <GroupBox Grid.Row="1" Header="Dados da encomenda" Padding="10" Margin="0 0 0 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Telefone:" VerticalAlignment="Center" Margin="0 5"/>
                <TextBox x:Name="txtTelefone" Grid.Row="0" Grid.Column="1" Margin="0 5 15 5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Contribuinte/NIF:" VerticalAlignment="Center" Margin="0 5"/>
                <TextBox x:Name="txtNif" Grid.Row="0" Grid.Column="3" Margin="0 5 15 5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Qtd. Bacon:" VerticalAlignment="Center" Margin="0 5"/>
                <TextBox x:Name="txtQtdBacon" Grid.Row="1" Grid.Column="1" Margin="0 5 15 5" Text="0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Qtd. Tofu:" VerticalAlignment="Center" Margin="0 5"/>
                <TextBox x:Name="txtQtdTofu" Grid.Row="1" Grid.Column="3" Margin="0 5 15 5" Text="0"/>

                <!-- [LOCALIZADOR: MainWindow.xaml | COM-003] Botões principais: nova encomenda, guardar e anular. -->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0 10 0 0">
                    <Button Content="Nova" Width="90" Margin="0 0 8 0" Click="Nova_Click"/>
                    <Button Content="Guardar" Width="90" Margin="0 0 8 0" Click="Guardar_Click"/>
                    <Button Content="Anular" Width="90" Margin="0 0 8 0" Click="Anular_Click"/>
                    <TextBlock Text="Preços: Bacon 10€ | Tofu 9€" VerticalAlignment="Center" Margin="15 0 0 0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- [LOCALIZADOR: MainWindow.xaml | COM-004] Tabela onde aparecem as encomendas guardadas na lista em memória. -->
        <DataGrid x:Name="dgEncomendas"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgEncomendas_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="130"/>
                <DataGridTextColumn Header="NIF" Binding="{Binding Nif}" Width="130"/>
                <DataGridTextColumn Header="Bacon" Binding="{Binding QuantidadeBacon}" Width="90"/>
                <DataGridTextColumn Header="Tofu" Binding="{Binding QuantidadeTofu}" Width="90"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:C}}" Width="120"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- [LOCALIZADOR: MainWindow.xaml | COM-005] Resumo final com total faturado e número de encomendas ativas. -->
        <Border Grid.Row="3" Background="#EEEEEE" Padding="10" Margin="0 12 0 0">
            <TextBlock x:Name="txtResumo" FontSize="16" FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>
